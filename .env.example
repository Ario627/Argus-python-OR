# ============================================================================
# ARGUS Optimization Service - Environment Configuration Template
# ============================================================================
# Copy this file to .env and update values for your environment.
# WARNING: Never commit .env files to version control!
# ============================================================================

# Server Configuration
PORT=8001                              # HTTP server port
HOST=0.0.0.0                          # Bind address (0.0.0.0 for Docker)
MOCK_MODE=false                       # Enable stub mode for testing (true/false)
LOG_LEVEL=INFO                        # Logging level (DEBUG, INFO, WARNING, ERROR)

# Optimization Engine
SOLVER_TIME_LIMIT_DAILY_MS=30000      # Daily plan optimization timeout (ms)
SOLVER_TIME_LIMIT_RECOVERY_MS=5000    # Swarm recovery optimization timeout (ms)

# Cost Parameters
LOW_VOLUME_SKIP_PENALTY=100           # Penalty for skipping low-volume destination
MANDATORY_PENALTY=1000000             # Penalty for unfeasible mandatory destination